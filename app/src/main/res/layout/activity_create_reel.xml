<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/rounded_corners_top"
    tools:context=".Activity.CreateReelActivity">

    <LinearLayout
        android:orientation="vertical"
        android:background="#fff"
        android:layout_width="match_parent"
        android:layout_height="match_parent">


        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:padding="10dp">
            <ImageView
                android:layout_width="wrap_content"
                android:layout_alignParentStart="true"
                android:id="@+id/back"
                android:backgroundTint="@color/black"
                android:src="@drawable/outline_arrow_back_ios_24"
                android:layout_height="wrap_content">
            </ImageView>

            <TextView
                android:text="Create Reel"
                android:textStyle="bold"
                android:textSize="18sp"
                android:id="@+id/reeltxt"
                android:backgroundTint="@color/black"
                android:layout_centerInParent="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <ImageView
                android:layout_width="wrap_content"
                android:layout_alignParentEnd="true"
                android:backgroundTint="@color/black"
                android:src="@drawable/setting_icon"
                android:layout_height="wrap_content">
            </ImageView>

        </RelativeLayout>


        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp">

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:gravity="center"
                android:layout_height="wrap_content">


                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginHorizontal="12dp">

                    <LinearLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:background="@drawable/circle_background"
                        android:backgroundTint="@color/grey_2">

                        <ImageView
                            android:src="@drawable/ic_camera"
                            android:layout_width="20dp"
                            app:tint="@color/black"
                            android:layout_height="20dp"/>
                    </LinearLayout>

                    <TextView
                        android:text="Camera"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:textSize="@dimen/dimen_14sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>


                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginHorizontal="12dp">

                    <LinearLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:background="@drawable/circle_background"
                        android:backgroundTint="@color/grey_2">

                        <ImageView
                            android:src="@drawable/ic_music"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            app:tint="@color/black"
                           />
                    </LinearLayout>

                    <TextView
                        android:text="Music"
                        android:layout_marginTop="6dp"
                        android:gravity="center"  android:textSize="@dimen/dimen_14sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>


                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginHorizontal="12dp">

                    <LinearLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:background="@drawable/circle_background"
                        android:backgroundTint="@color/grey_2">

                        <ImageView
                            android:src="@drawable/cloud"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            app:tint="@color/black" />
                    </LinearLayout>

                    <TextView
                        android:text="Templates"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:textSize="@dimen/dimen_14sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginHorizontal="12dp">

                    <LinearLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:background="@drawable/circle_background"
                        android:backgroundTint="@color/grey_2">

                        <ImageView
                            android:src="@drawable/draft"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            app:tint="@color/black" />
                    </LinearLayout>

                    <TextView
                        android:text="Drafts"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:textSize="@dimen/dimen_14sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginHorizontal="12dp">

                    <LinearLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:background="@drawable/circle_background"
                        android:backgroundTint="@color/grey_2">

                        <ImageView
                            android:src="@drawable/authentication"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            app:tint="@color/black" />
                    </LinearLayout>

                    <TextView
                        android:text="Green Screen"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:textSize="@dimen/dimen_14sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginHorizontal="12dp">

                    <LinearLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:background="@drawable/circle_background"
                        android:backgroundTint="@color/grey_2">

                        <ImageView
                            android:src="@drawable/effect"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            app:tint="@color/black" />
                    </LinearLayout>

                    <TextView
                        android:text="Effects"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:textSize="@dimen/dimen_14sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

            </LinearLayout>
        </HorizontalScrollView>


        <LinearLayout
            android:orientation="horizontal"
            android:padding="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:id="@+id/galleryLayout"
                android:orientation="horizontal"
                >
                <TextView
                    android:text="Gallery"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/black"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:src="@drawable/ic_arrow_drop_down"
                    app:tint="@color/black" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                app:cardCornerRadius="@dimen/dimen_8dp"
                app:cardBackgroundColor="@color/grey_2"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_margin="4dp"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/gallery"
                        />
                    <TextView
                        android:text="Select Multiple"
                        android:textColor="@color/black"
                        android:layout_margin="4dp"
                        android:layout_height="wrap_content"
                        android:layout_width="100dp"/>
                </LinearLayout>


            </androidx.cardview.widget.CardView>


        </LinearLayout>

        <!-- RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/videoRecycler"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>