<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- ╔══════════════════════════════════════╗ -->
    <!-- ║           TOP TOOLBAR               ║ -->
    <!-- ╚══════════════════════════════════════╝ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="12dp"
        android:background="#000000">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="Create reel"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnPost"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Share"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="@drawable/btn_share_bg"
            android:stateListAnimator="@null" />

    </LinearLayout>

    <!-- ╔══════════════════════════════════════╗ -->
    <!-- ║     SCROLLABLE CONTENT AREA         ║ -->
    <!-- ╚══════════════════════════════════════╝ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── User Info Row ───────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="12dp"
                android:paddingBottom="10dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/circle_bg">

                    <ImageView
                        android:id="@+id/ivUserAvatar"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:scaleType="centerCrop"
                        android:clipToOutline="true"
                        android:background="@drawable/circle_bg"
                        android:contentDescription="Avatar" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:id="@+id/tvUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Your Name"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />

                    <LinearLayout
                        android:id="@+id/llAudience"
                        android:layout_width="wrap_content"
                        android:layout_height="22dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/audience_bg"
                        android:paddingStart="8dp"
                        android:paddingEnd="5dp"
                        android:layout_marginTop="3dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="11dp"
                            android:layout_height="11dp"
                            android:src="@drawable/user_icon"
                            android:layout_marginEnd="3dp"
                            android:contentDescription="public" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Public"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="13dp"
                            android:layout_height="13dp"
                            android:src="@drawable/ic_arrow_drop_down"
                            app:tint="#FFFFFF"
                            android:layout_marginStart="1dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ── Caption + Thumbnail side by side (FB Reels style) ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingBottom="14dp"
                android:gravity="top">

                <!-- Caption input — takes remaining space -->
                <EditText
                    android:id="@+id/etCaption"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="100dp"
                    android:gravity="top"
                    android:hint="Write a caption…"
                    android:textColorHint="#555555"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:lineSpacingExtra="3dp"
                    android:background="@null"
                    android:inputType="textMultiLine|textCapSentences"
                    android:maxLines="6"
                    android:paddingEnd="10dp" />

                <!-- Thumbnail preview — small, right side -->
                <FrameLayout
                    android:layout_width="@dimen/_120sdp"
                    android:layout_height="@dimen/_120sdp"
                    android:background="@drawable/bg_round_white">

                    <ImageView
                        android:id="@+id/imageView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:contentDescription="Thumbnail" />

                    <!-- Bottom gradient -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_gravity="bottom"
                        android:background="@drawable/gradient_bottom" />

                    <!-- Duration badge -->
                    <TextView
                        android:id="@+id/tvDurationBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="5dp"
                        android:text="0:00"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:background="@drawable/duration_badge_bg"
                        android:paddingStart="5dp"
                        android:paddingEnd="5dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp" />
                </FrameLayout>
            </LinearLayout>

            <!-- ── Full divider ─────────────────────────────────── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="#2A2A2A" />

            <!-- ╔══════════════════════════════════════╗ -->
            <!-- ║         HASHTAG SECTION             ║ -->
            <!-- ╚══════════════════════════════════════╝ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <!-- Input row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_tag"
                        app:tint="#1877F2"
                        android:layout_marginEnd="14dp" />

                    <EditText
                        android:id="@+id/etHashtag"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Search hashtags…"
                        android:textColorHint="#555555"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:background="@null"
                        android:inputType="text"
                        android:imeOptions="actionDone"
                        android:maxLines="1" />

                </LinearLayout>

                <!--
                    Suggestions list — tap karo to chip add ho jaata hai
                    visibility GONE by default, VISIBLE jab type karo
                -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvHashtagSuggestions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="50dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginBottom="6dp"
                    android:background="@drawable/suggestion_bg"
                    android:elevation="4dp"
                    android:nestedScrollingEnabled="false"
                    android:visibility="gone" />

                <!-- Selected hashtag chips -->
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupHashtags"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="50dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="4dp"
                    app:chipSpacingHorizontal="4dp"
                    app:chipSpacingVertical="2dp" />

            </LinearLayout>

            <!-- ── Divider ──────────────────────────────────────── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginStart="16dp"
                android:background="#2A2A2A" />

            <!-- ── Also share to Feed toggle ───────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_filter"
                    app:tint="#1877F2"
                    android:layout_marginEnd="14dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Also share to Feed"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchShareToFeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <!-- ── Divider ──────────────────────────────────────── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginStart="16dp"
                android:background="#2A2A2A" />

            <!-- ── Location Row ─────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/llLocation"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_location"
                    app:tint="#1877F2"
                    android:layout_marginEnd="14dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tag location"
                    android:textColor="#AAAAAA"
                    android:textSize="15sp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="#555555" />
            </LinearLayout>

            <!-- ── Divider ──────────────────────────────────────── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginStart="16dp"
                android:background="#2A2A2A" />

            <!-- ── Tag People Row ───────────────────────────────── -->
            <LinearLayout
                android:id="@+id/llTagPeople"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/add_user"
                    app:tint="#1877F2"
                    android:layout_marginEnd="14dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tag people"
                    android:textColor="#AAAAAA"
                    android:textSize="15sp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="#555555" />
            </LinearLayout>

            <!-- Bottom spacing -->
            <View
                android:layout_width="match_parent"
                android:layout_height="24dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ╔══════════════════════════════════════╗ -->
    <!-- ║     LOADING BAR — pinned bottom     ║ -->
    <!-- ╚══════════════════════════════════════╝ -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:indeterminate="true"
        android:indeterminateTint="#1877F2"
        android:visibility="gone" />

</LinearLayout>