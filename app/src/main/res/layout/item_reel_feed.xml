<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- ExoPlayer View — fullscreen -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/reelPlayerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        app:use_controller="false"
        app:surface_type="surface_view"
        app:resize_mode="zoom"
        />

    <!-- Thumbnail shown before video loads -->
    <ImageView
        android:id="@+id/reelThumbnail"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="visible" />

    <!-- Buffering spinner -->
    <ProgressBar
        android:id="@+id/reelLoadingBar"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center"
        android:indeterminateTint="@android:color/white"
        android:visibility="gone" />

    <!-- Heart animation -->
    <ImageView
        android:id="@+id/heartOverlay"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_favorite_filled"
        android:visibility="gone"
        app:tint="#FFFF3B30" />

    <!-- Play/Pause centre icon -->
    <ImageView
        android:id="@+id/playPauseOverlay"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_play_circle_outline"
        android:alpha="0.0"
        android:visibility="visible"
        app:tint="@android:color/white" />

    <!-- Seek Back 5s — left zone (tap area large) -->
    <FrameLayout
        android:id="@+id/seekBackZone"
        android:layout_width="100dp"
        android:layout_height="match_parent"
        android:layout_gravity="start">

        <ImageView
            android:id="@+id/btnSeekBack"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:src="@drawable/replay_5_24dp"
            android:alpha="0.0"
            android:padding="8dp"
            app:tint="@android:color/white" />
    </FrameLayout>

    <!-- Seek Forward 5s — right zone -->
    <FrameLayout
        android:id="@+id/seekForwardZone"
        android:layout_width="100dp"
        android:layout_height="match_parent"
        android:layout_gravity="end">

        <ImageView
            android:id="@+id/btnSeekForward"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:src="@drawable/forward_5_24dp"
            android:alpha="0.0"
            android:padding="8dp"
            app:tint="@android:color/white" />
    </FrameLayout>

    <!-- Bottom gradient -->
    <View
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:layout_gravity="bottom"
        android:background="@drawable/gradient_bottom_reel" />

    <!-- Bottom-left info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:orientation="vertical"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="80dp"
        android:layout_marginBottom="20dp">

        <!-- Author -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/authorAvatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/circle_background" />

            <TextView
                android:id="@+id/authorName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:text="Author Name" />

            <TextView
                android:id="@+id/btnFollow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="+ Follow"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/rounded_border_bg" />

        </LinearLayout>

        <!-- Caption -->
        <TextView
            android:id="@+id/descriptionTxt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:lineSpacingMultiplier="1.2" />

        <!-- Music -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <ImageView
                android:id="@+id/musicDisc"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_music"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/musicName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:text="Original Sound" />

        </LinearLayout>

        <!-- Duration row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/tvCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:text="0:00" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#99FFFFFF"
                android:textSize="11sp"
                android:text=" / " />

            <TextView
                android:id="@+id/tvTotalTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#99FFFFFF"
                android:textSize="11sp"
                android:text="0:00" />

        </LinearLayout>

    </LinearLayout>

    <!-- Right side actions -->
    <LinearLayout
        android:layout_width="56dp"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:orientation="vertical"
        android:layout_marginEnd="6dp"
        android:layout_marginBottom="24dp"
        android:gravity="center_horizontal">

        <!-- Like -->
        <ImageView
            android:id="@+id/btnLike"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_favorite_border"
            app:tint="@android:color/white" />

        <TextView
            android:id="@+id/likeCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:layout_marginBottom="20dp"
            android:text="0" />

        <!-- Comment -->
        <ImageView
            android:id="@+id/btnComment"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_comment"
            app:tint="@android:color/white" />

        <TextView
            android:id="@+id/commentCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:layout_marginBottom="20dp"
            android:text="0" />

        <!-- Share -->
        <ImageView
            android:id="@+id/btnShare"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_share"
            android:layout_marginBottom="20dp"
            app:tint="@android:color/white" />

        <!-- Bookmark -->
        <ImageView
            android:id="@+id/btnBookmark"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_bookmark"
            android:layout_marginBottom="20dp"
            app:tint="@android:color/white" />

        <!-- More -->
        <ImageView
            android:id="@+id/btnMore"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_more_vert"
            android:layout_marginBottom="20dp"
            app:tint="@android:color/white" />

        <!-- Mute -->
        <ImageView
            android:id="@+id/btnMute"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_volume_up"
            app:tint="@android:color/white" />

    </LinearLayout>

    <!-- Bottom SeekBar -->
    <SeekBar
        android:id="@+id/videoSeekBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="2dp"
        android:max="1000"
        android:progress="0"
        android:progressTint="@android:color/white"
        android:thumbTint="@android:color/white"
        android:progressBackgroundTint="#44FFFFFF"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:minHeight="2dp" />

</FrameLayout>