<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Define a custom style to hide text labels -->
    <style name="BottomNavigationViewStyle" parent="Widget.Design.BottomNavigationView">
        <item name="itemTextAppearance">@style/BottomNavigationViewTextAppearance</item>
    </style>

    <style name="BottomNavigationViewTextAppearance" parent="TextAppearance.AppCompat">
        <item name="android:textSize">0sp</item> <!-- Hide text by setting size to 0sp -->
    </style>

        <style name="Divider">
            <item name="android:layout_width">match_parent</item>
            <item name="android:layout_height">1dp</item>
            <item name="android:background">#E6E6E6</item>
        </style>

    <style name="CircleImage">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>


</resources>